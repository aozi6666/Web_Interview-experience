        <mxCell id="1nMDwmI68g-W47vcw8KW-11" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;line-height: 19px; white-space-collapse: preserve; color: rgb(228, 228, 228); background-color: rgb(24, 24, 24);&quot;&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-wrap-mode: nowrap; background-color: rgb(24, 24, 24);&quot;&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-style: italic;&quot;&gt;// Gateway RPC call&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-wrap-mode: nowrap; background-color: rgb(24, 24, 24);&quot;&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; ipcMain.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;handle&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;gateway:rpc&#39;&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;async&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;_&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;method&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;string&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;params&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;?&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;unknown&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;timeoutMs&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;?&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;number&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;) &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-wrap-mode: nowrap; background-color: rgb(24, 24, 24);&quot;&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;try&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;orphans: 4;&quot;&gt;&lt;font color=&quot;#e4e4e4&quot; face=&quot;Consolas, Courier New, monospace&quot;&gt;&lt;span style=&quot;font-size: 14px; text-wrap-mode: nowrap; background-color: rgb(24, 24, 24);&quot;&gt;      // 调用 主进程的 GatewayManager.rpc 封装方法（只转发）&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-wrap-mode: nowrap; background-color: rgb(24, 24, 24);&quot;&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;result&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; = &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;await&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; gatewayManager.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;rpc&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;method&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;params&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;timeoutMs&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-wrap-mode: nowrap; background-color: rgb(24, 24, 24);&quot;&gt;      // 结果打包 return 回 渲染进程&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-wrap-mode: nowrap; background-color: rgb(24, 24, 24);&quot;&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;return&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; { success: true, &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;result&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; };&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-wrap-mode: nowrap; background-color: rgb(24, 24, 24);&quot;&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &amp;nbsp; }&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-wrap-mode: nowrap; background-color: rgb(24, 24, 24);&quot;&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; });&lt;/span&gt;&lt;/div&gt;&lt;font color=&quot;#e4e4e4&quot; face=&quot;Consolas, Courier New, monospace&quot;&gt;&lt;span style=&quot;font-size: 14px; text-wrap-mode: nowrap; background-color: rgb(24, 24, 24);&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="796" x="1640" y="160" as="geometry" />
        </mxCell>
