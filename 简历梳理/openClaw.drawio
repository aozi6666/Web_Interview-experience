        <mxCell id="CriP8Mpn-Im69xwzzEPo-2" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;function&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #efb080;font-weight: bold;&quot;&gt;handleGatewayChatMessage&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;data&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;unknown&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;void&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;  // 动态导入&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;import&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;./chat&#39;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;).&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;then&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(({ &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;useChatStore&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; }) &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;     // 1）取出&lt;/span&gt; &lt;code data-start=&quot;4403&quot; data-end=&quot;4425&quot;&gt;gateway:chat-message&lt;/code&gt; 的 payload&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;chatData&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;data&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;as&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;Record&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;string&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;unknown&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;payload&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;chatData&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;message&lt;/span&gt;;&lt;/div&gt;    &lt;/div&gt;&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;    // 2）“带 state 的标准聊天事件”（thinking），走 useChatStore&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;payload&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;state&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;) {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;useChatStore&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;getState&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;().&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;handleChatEvent&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;payload&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;return&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; }&lt;/span&gt;&lt;/div&gt;   &lt;/div&gt;&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;    // 3）包装成一个 final 消息，再交给 useChatStore&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;useChatStore&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;getState&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;().&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;handleChatEvent&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;({&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;state&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;final&#39;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;message&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;payload&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;runId&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;chatData&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;runId&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;??&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;payload&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;runId&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; });&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; }).&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;catch&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(() &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {});&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="380" width="490" x="-3990" y="1810" as="geometry" />
        </mxCell>
        <mxCell id="CriP8Mpn-Im69xwzzEPo-3" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;function&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #efb080;font-weight: bold;&quot;&gt;handleGatewayNotification&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;notification&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; { &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;method&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;?&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;string&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;params&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;?&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;Record&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;string&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;unknown&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;gt; } &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;|&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;undefined&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;void&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;payload&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;notification&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;p&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;payload&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;params&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;  &lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;  // 取出 data 和 phase阶段（started、completed、done）&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;data&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;p&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;data&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;amp;&amp;amp;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;typeof&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;p&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;data&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;===&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;object&#39;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;) &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;?&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;p&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;data&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;as&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;Record&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;string&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;unknown&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;gt;) &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {};&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;phase&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;data&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;phase&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;??&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;p&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;phase&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;  // ！给 thinking 内容展示的 data&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;hasChatData&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&q