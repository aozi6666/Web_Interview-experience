;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #ebc88d;&quot;&gt;set&lt;/span&gt;((&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;s&lt;/span&gt;) &lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;              // 4）把当前 streamingMessage “快照-中间thinking过程”保存，防止 thinking / tool_use 被后面的消息覆盖&lt;/div&gt;&lt;div&gt;              //  &lt;code data-start=&quot;4950&quot; data-end=&quot;4965&quot;&gt;currentStream： 包含 thinking block、 tool_use block、中间分析文本&lt;/code&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;currentStream&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;s&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;streamingMessage&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;as&lt;/span&gt; &lt;span style=&quot;color: #efb080;&quot;&gt;RawMessage&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;|&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;null&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;snapshotMsgs&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #efb080;&quot;&gt;RawMessage&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;[]&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;[]&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #aaa0fa;&quot;&gt;currentStream&lt;/span&gt;) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;streamRole&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;currentStream&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;role&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #aaa0fa;&quot;&gt;streamRole&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;===&lt;/span&gt; &lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;assistant&#39;&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;||&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;streamRole&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;===&lt;/span&gt; undefined) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;font-style: italic;&quot;&gt;// Use message&#39;s own id if available, otherwise derive a stable one from runId&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;snapId&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;currentStream&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;id &lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;||&lt;/span&gt; &lt;span style=&quot;color: rgb(227, 148, 220);&quot;&gt;`&lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;${&lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;runId&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt; || &lt;/span&gt;&lt;span style=&quot;color: rgb(227, 148, 220);&quot;&gt;&#39;run&#39;&lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;}&lt;/span&gt;&lt;span style=&quot;color: rgb(227, 148, 220);&quot;&gt;-turn-&lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;${&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221); font-style: italic;&quot;&gt;s&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;messages&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;length&lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;}&lt;/span&gt;&lt;span style=&quot;color: rgb(227, 148, 220);&quot;&gt;`&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #d6d6dd;&quot;&gt;!&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;s&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;messages&lt;/span&gt;.&lt;span style=&quot;color: #efb080;&quot;&gt;some&lt;/span&gt;(&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;m&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;m&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;id&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;===&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;snapId&lt;/span&gt;)) {&lt;/div&gt;&lt;div&gt;                     // 保存到数组，后面塞进 messages&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;snapshotMsgs&lt;/span&gt;.&lt;span style=&quot;color: #efb080;&quot;&gt;push&lt;/span&gt;({&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;...&lt;/span&gt;(&lt;span style=&quot;color: #aaa0fa;&quot;&gt;currentStream&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;as&lt;/span&gt; &lt;span style=&quot;color: #efb080;&quot;&gt;RawMessage&lt;/span&gt;),&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;role&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;assistant&#39;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;id&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;snapId&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; });&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;return&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;               // 5）将 中间thinking 塞进 message 展示&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;messages&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;snapshotMsgs&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;length&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;gt;&lt;/span&gt; &lt;span style=&quot;color: #ebc88d;&quot;&gt;0&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;?&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;[...&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;s&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;messages&lt;/span&gt;, &lt;span style=&quot;color: #d6d6dd;&quot;&gt;...&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;snapshotMsgs&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;]&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;s&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;messages&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;streamingText&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;&#39;&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;streamingMessage&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; null,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;pendingFinal&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; true,&lt;/div&gt;&lt;div&gt;                // 文件先不挂 UI， 先存到 &lt;code data-start=&quot;2857&quot; data-end=&quot;2876&quot;&gt;pendingToolImages（等下一条真正 assistant 消息到来时再挂上）&lt;/code&gt;&lt;/div&gt;&lt;div&gt;&lt;code data-start=&quot;2857&quot; data-end=&quot;2876&quot;&gt;                 // &lt;/code&gt;&lt;code data-start=&quot;3169&quot; data-end=&quot;3188&quot;&gt;pendingToolImages：“刚刚工具跑出来的附件暂存区”&lt;/code&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;pendingToolImages&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;toolFiles&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;length&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;gt;&lt;/span&gt; &lt;span style=&quot;color: #ebc88d;&quot;&gt;0&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;?&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;[...&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;s&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;pendingToolImages&lt;/span&gt;, &lt;span style=&quot;color: #d6d6dd;&quot;&gt;...&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;toolFiles&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;]&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;s&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;pendingToolImages&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;                // 6）UI 还会展示  “工具执行状态”（比如 &lt;code data-start=&quot;5492&quot; data-end=&quot;5504&quot;&gt;write_file&lt;/code&gt; 正在运行、 &lt;code data-start=&quot;5512&quot; data-end=&quot;5524&quot;&gt;write_file&lt;/code&gt; 已完成...）&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;streamingTools&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;updates&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;length&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;gt;&lt;/span&gt; &lt;span style=&quot;color: #ebc88d;&quot;&gt;0&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;?&lt;/span&gt; &lt;span style=&quot;color: #ebc88d;&quot;&gt;upsertToolStatuses&lt;/span&gt;(&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;s&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;streamingTools&lt;/span&gt;, &lt;span style=&quot;color: #aaa0fa;&quot;&gt;updates&lt;/span&gt;) &lt;span style=&quot;color: #82d2ce;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;s&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;streamingTools&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; };&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; });&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;break&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;          // 二、真正 assistant final ：流式展示AI回复框消息&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;toolOnly&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #ebc88d;&quot;&gt;isToolOnlyMessage&lt;/span&gt;(&lt;span style=&quot;color: #aaa0fa;&quot;&gt;finalMsg&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;hasOutput&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #ebc88d;&quot;&gt;hasNonToolAssistantContent&lt;/span&gt;(&lt;span style=&quot;color: #aaa0fa;&quot;&gt;finalMsg&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;msgId&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;finalMsg&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;id&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;||&lt;/span&gt; (&lt;span style=&quot;color: #aaa0fa;&quot;&gt;toolOnly&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;?&lt;/span&gt; &lt;span style=&quot;color: #e394dc;&quot;&gt;`run-&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;${&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;runId&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;}&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;-tool-&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;${&lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;Date&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;now&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;()&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;}&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;`&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #e394dc;&quot;&gt;`run-&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;${&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;runId&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;}&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;`&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #ebc88d;&quot;&gt;set&lt;/span&gt;((&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;s&lt;/span&gt;) &lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;nextTools&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;updates&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;length&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;gt;&lt;/span&gt; &lt;span style=&quot;color: #ebc88d;&quot;&gt;0&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;?&lt;/span&gt; &lt;span style=&quot;color: #ebc88d;&quot;&gt;upsertToolStatuses&lt;/span&gt;(&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;s&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;streamingTools&lt;/span&gt;, &lt;span style=&quot;color: #aaa0fa;&quot;&gt;updates&lt;/span&gt;) &lt;span style=&quot;color: #82d2ce;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;s&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;streamingTools&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;streamingTools&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;hasOutput&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;?&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;[]&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;nextTools&lt;/span&gt;;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;font-style: italic;&quot;&gt;// &lt;/span&gt;把&lt;code data-start=&quot;2857&quot; data-end=&quot;2876&quot;&gt; &lt;/code&gt;&lt;code data-start=&quot;3169&quot; data-end=&quot;3188&quot;&gt;pendingToolImages中 “&lt;/code&gt;附件“ 挂到UI（附件卡片出现）&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;pendingImgs&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;s&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;pendingToolImages&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;msgWithImages&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #efb080;&quot;&gt;RawMessage&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;pendingImgs&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;length&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;gt;&lt;/span&gt; &lt;span style=&quot;color: #ebc88d;&quot;&gt;0&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;?&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;...&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;finalMsg&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;role&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; (&lt;span style=&quot;color: #aaa0fa;&quot;&gt;finalMsg&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;role&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;||&lt;/span&gt; &lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;assistant&#39;&lt;/span&gt;) &lt;span style=&quot;color: #82d2ce;&quot;&gt;as&lt;/span&gt; &lt;span style=&quot;color: #efb080;&quot;&gt;RawMessage&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;[&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;role&#39;&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;]&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;id&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #87c3ff;&quot;&gt;msgId&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;_attachedFiles&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;[...&lt;/span&gt;(&lt;span style=&quot;color: #aaa0fa;&quot;&gt;finalMsg&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;_attachedFiles&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;||&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;[]&lt;/span&gt;), &lt;span style=&quot;color: #d6d6dd;&quot;&gt;...&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;pendingImgs&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;]&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;:&lt;/span&gt; { &lt;span style=&quot;color: #d6d6dd;&quot;&gt;...&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;finalMsg&lt;/span&gt;, &lt;span style=&quot;color: #aaa0fa;&quot;&gt;role&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; (&lt;span style=&quot;color: #aaa0fa;&quot;&gt;finalMsg&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;role&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;||&lt;/span&gt; &lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;assistant&#39;&lt;/span&gt;) &lt;span style=&quot;color: #82d2ce;&quot;&gt;as&lt;/span&gt; &lt;span style=&quot;color: #efb080;&quot;&gt;RawMessage&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;[&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;role&#39;&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;]&lt;/span&gt;, &lt;span style=&quot;color: #aaa0fa;&quot;&gt;id&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;msgId&lt;/span&gt; };&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;clearPendingImages&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; { &lt;span style=&quot;color: #aaa0fa;&quot;&gt;pendingToolImages&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;[]&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;as&lt;/span&gt; &lt;span style=&quot;color: #efb080;&quot;&gt;AttachedFileMeta&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;[]&lt;/span&gt; };&lt;/div&gt;&lt;br&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;...&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; },&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;div style=&quot;line-height: 19px;&quot;&gt;&lt;font color=&quot;#82d2ce&quot;&gt;}&lt;/font&gt;&lt;/div&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="2550" width="900" x="-5660" y="2430" as="geometry" />
        </mxCell>
        <mxCell id="CriP8Mpn-Im69xwzzEPo-7" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;协调整轮聊天的生命周期：开始、流式中、工具过程、最终落库、报错、终止。&lt;/font&gt;" vertex="1">
          <mxGeometry height="40" width="660" x="-5640" y="2390" as="geometry" />
        </mxCell>
        <UserObject label="&lt;p data-start=&quot;39&quot; data-end=&quot;89&quot;&gt;&lt;span data-start=&quot;39&quot; data-end=&quot;89&quot;&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;&lt;code data-start=&quot;41&quot; data-end=&quot;55&quot; style=&quot;&quot;&gt;case &#39;final&#39;&lt;/code&gt; 不是“收到最终消息就直接显示”这么简单。它其实在做 3 件事：&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;ol data-start=&quot;92&quot; data-end=&quot;258&quot;&gt;&lt;li data-start=&quot;92&quot; data-end=&quot;127&quot;&gt;&lt;p data-start=&quot;95&quot; data-end=&quot;127&quot;&gt;&lt;span data-start=&quot;95&quot; data-end=&quot;127&quot;&gt;&lt;font size=&quot;3&quot;&gt;把中间的 thinking / tool_use 先保住&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;130&quot; data-end=&quot;167&quot;&gt;&lt;p data-start=&quot;133&quot; data-end=&quot;167&quot;&gt;&lt;span data-start=&quot;133&quot; data-end=&quot;167&quot;&gt;&lt;font size=&quot;3&quot;&gt;把 tool_result 里产出的图片 / 文件先收集起来&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;170&quot; data-end=&quot;258&quot;&gt;&lt;p data-start=&quot;173&quot; data-end=&quot;258&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;span data-start=&quot;173&quot; data-end=&quot;220&quot; style=&quot;&quot;&gt;等真正 assistant 最终回复来了，再把这些文件挂到那条最终回复上显示成附件卡片&lt;/span&gt; &lt;/font&gt;&lt;span class=&quot;&quot; data-state=&quot;closed&quot;&gt;&lt;span class=&quot;relative inline-flex items-center&quot;&gt;&lt;button class=&quot;ms-1 flex h-[25px] text-[10px] leading-[13px] rounded-xl corner-superellipse/1.1 items-center justify-center gap-1 px-2 relative text-token-text-secondary! hover:text-token-text-primary! hover:bg-token-bg-secondary dark:bg-token-main-surface-secondary dark:hover:bg-token-bg-secondary bg-[#f4f4f4]&quot;&gt;&lt;svg xmlns=&quot;http://www.w3.org/2000/svg&quot; width=&quot;20&quot; height=&quot;20&quot; aria-hidden=&quot;true&quot; class=&quot;h-[16px] w-[16px] object-contain text-token-text-primary! flex-none icon-sm&quot;&gt;&lt;/svg&gt;&lt;p class=&quot;not-prose mt-0! mb-0! flex-auto truncate&quot;&gt;&lt;/p&gt;&lt;/button&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;" link="&lt;p data-start=&quot;39&quot; data-end=&quot;89&quot;&gt;&lt;strong data-start=&quot;39&quot; data-end=&quot;89&quot;&gt;&lt;code data-start=&quot;41&quot; data-end=&quot;55&quot;&gt;case &#39;final&#39;&lt;/code&gt; 不是“收到最终消息就直接显示”这么简单。它其实在做 3 件事：&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;ol data-start=&quot;92&quot; data-end=&quot;258&quot;&gt;&#xa;&lt;li data-start=&quot;92&quot; data-end=&quot;127&quot;&gt;&#xa;&lt;p data-start=&quot;95&quot; data-end=&quot;127&quot;&gt;&lt;strong data-start=&quot;95&quot; data-end=&quot;127&quot;&gt;把中间的 thinking / tool_use 先保住&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-start=&quot;130&quot; data-end=&quot;167&quot;&gt;&#xa;&lt;p data-start=&quot;133&quot; data-end=&quot;167&quot;&gt;&lt;strong data-start=&quot;133&quot; data-end=&quot;167&quot;&gt;把 tool_result 里产出的图片 / 文件先收集起来&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-start=&quot;170&quot; data-end=&quot;258&quot;&gt;&#xa;&lt;p data-start=&quot;173&quot; data-end=&quot;258&quot;&gt;&lt;strong data-start=&quot;173&quot; data-end=&quot;220&quot;&gt;等真正 assistant 最终回复来了，再把这些文件挂到那条最终回复上显示成附件卡片&lt;/strong&gt; &lt;span class=&quot;&quot; data-state=&quot;closed&quot;&gt;&lt;span class=&quot;relative inline-flex items-center&quot;&gt;&lt;button class=&quot;ms-1 flex h-[25px] text-[10px] leading-[13px] rounded-xl corner-superellipse/1.1 items-center justify-center gap-1 px-2 relative text-token-text-secondary! hover:text-token-text-primary! hover:bg-token-bg-secondary dark:bg-token-main-surface-secondary dark:hover:bg-token-bg-secondary bg-[#f4f4f4]&quot;&gt;&lt;svg xmlns=&quot;http://www.w3.org/2000/svg&quot; width=&quot;20&quot; height=&quot;20&quot; aria-hidden=&quot;true&quot; class=&quot;h-[16px] w-[16px] object-contain text-token-text-primary! flex-none icon-sm&quot;&gt;&lt;/svg&gt;&lt;p class=&quot;not-prose mt-0! mb-0! flex-auto truncate&quot;&gt;&lt;/p&gt;&lt;/button&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;" id="CriP8Mpn-Im69xwzzEPo-8">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1">
