        <mxCell id="1nMDwmI68g-W47vcw8KW-31" parent="1" style="text;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;rounded=0;fillColor=#333333;" value="&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;// 应用层 握手成功时触发&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(239, 176, 128); font-weight: bold;&quot;&gt;resolveOnce&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; () &lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;if&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: rgb(135, 195, 255);&quot;&gt;settled&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;) &lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;return&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(135, 195, 255);&quot;&gt;settled&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; true;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(235, 200, 141);&quot;&gt;cleanupHandshakeRequest&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;();&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;      // resolve通过连接的 ws 对象&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(235, 200, 141);&quot;&gt;resolve&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;ws&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; };&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="290" x="2980" y="-1360" as="geometry" />
        </mxCell>
        <mxCell id="1nMDwmI68g-W47vcw8KW-33" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;div style=&quot;background-color: rgb(24, 24, 24); line-height: 19px; color: rgb(228, 228, 228);&quot;&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&lt;div style=&quot;line-height: 19px;&quot;&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;export&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;class&lt;/span&gt; &lt;span style=&quot;color: #87c3ff;&quot;&gt;GatewayManager&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;extends&lt;/span&gt; &lt;span style=&quot;color: #87c3ff;&quot;&gt;EventEmitter&lt;/span&gt; {&lt;/div&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;/**&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;&amp;nbsp; &amp;nbsp;* Connect WebSocket to Gateway (得到 this.ws)&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;&amp;nbsp; &amp;nbsp;*/&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;private&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;async&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #efb080;font-weight: bold;&quot;&gt;connect&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;port&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;number&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;_externalToken&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;?&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;string&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;Promise&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;void&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;gt; {&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;    // &lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;this.ws: &lt;/span&gt;&lt;code data-start=&quot;807&quot; data-end=&quot;823&quot; style=&quot;color: rgb(228, 228, 228);&quot;&gt;GatewayManager&lt;/code&gt;&lt;font color=&quot;#e4e4e4&quot;&gt; 这个类实例上的一个“属性”&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;font color=&quot;#e4e4e4&quot;&gt;    // connect 成功，ws实例对象挂到 this 上&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #cc7c8a;&quot;&gt;this&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;ws&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;await&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;connectGatewaySocket&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;({&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;port&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;deviceIdentity&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #cc7c8a;&quot;&gt;this&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;deviceIdentity&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;platform&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;process&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;platform&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;pendingRequests&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #cc7c8a;&quot;&gt;this&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;pendingRequests&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #efb080;font-weight: bold;&quot;&gt;getToken&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;async&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; () &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;await&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;import&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;../utils/store&#39;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;).&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;then&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(({ &lt;/span&gt;&lt;span style=&quot;color: #efb080;font-weight: bold;&quot;&gt;getSetting&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; }) &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;getSetting&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;gatewayToken&#39;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)),&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; ... &lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;      // &lt;/span&gt;“收到 Gateway 发来的消息”，每次 ws 收到一条消息触发(单位：message 帧)&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;      // “onMessage = 所有从 Gateway 回来的数据入口”&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;      // 底层监听 &lt;code data-start=&quot;605&quot; data-end=&quot;623&quot;&gt;ws.on(&#39;message&#39;)&lt;/code&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #efb080;font-weight: bold;&quot;&gt;onMessage&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;message&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;) &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #cc7c8a;&quot;&gt;this&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;handleMessage&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;message&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; },&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; });&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; }&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;// 判断“这条消息到底属于哪一类”，走不同分支。&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;div style=&quot;line-height: 19px;&quot;&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;private&lt;/span&gt; &lt;span style=&quot;color: #efb080;font-weight: bold;&quot;&gt;handleMessage&lt;/span&gt;(&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;message&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;unknown&lt;/span&gt;)&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;void&lt;/span&gt; {&lt;/div&gt;&lt;font color=&quot;#e4e4e4&quot; style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;msg&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;message&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;as&lt;/span&gt; &lt;span style=&quot;color: #efb080;&quot;&gt;Record&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;string&lt;/span&gt;, &lt;span style=&quot;color: #82d2ce;&quot;&gt;unknown&lt;/span&gt;&amp;gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font color=&quot;#e4e4e4&quot; face=&quot;Consolas, Courier New, monospace&quot;&gt;&lt;span style=&quot;font-size: 14px; white-space: pre;&quot;&gt;    // &lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; font-style: italic;&quot;&gt;case1: &lt;/span&gt;&lt;font color=&quot;#e4e4e4&quot; face=&quot;Consolas, Courier New, monospace&quot;&gt;&lt;span style=&quot;font-size: 14px; white-space: pre;&quot;&gt;某个 RPC 请求的“响应”： &lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; font-style: italic;&quot;&gt;type: &quot;res&quot;: &lt;/span&gt;&lt;font color=&quot;#e4e4e4&quot; face=&quot;Consolas, Courier New, monospace&quot;&gt;&lt;span style=&quot;font-size: 14px; white-space: pre;&quot;&gt;&lt;i&gt;对应着某个正在 await rpc(...) 的 Promise&lt;/i&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #aaa0fa;&quot;&gt;msg&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;type&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;===&lt;/span&gt; &lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;res&#39;&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;amp;&amp;amp;&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;typeof&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;msg&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;id&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;===&lt;/span&gt; &lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;string&#39;&lt;/span&gt;) {&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;      // 用 &lt;code data-start=&quot;1128&quot; data-end=&quot;1132&quot;&gt;id&lt;/code&gt; 去 &lt;code data-start=&quot;1135&quot; data-end=&quot;1152&quot;&gt;pendingRequests&lt;/code&gt; 里找原来那条请求&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;      // 找到后把它 resolve / reject&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #aaa0fa;&quot;&gt;msg&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;ok&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;===&lt;/span&gt; false &lt;span style=&quot;color: #d6d6dd;&quot;&gt;||&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;msg&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;error&lt;/span&gt;) {&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre;&quot;&gt;&lt;font color=&quot;#e4e4e4&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/font&gt;&lt;font color=&quot;#82d2ce&quot;&gt;... &lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #ebc88d;&quot;&gt;rejectPendingGatewayRequest&lt;/span&gt;(&lt;span style=&quot;color: #cc7c8a;&quot;&gt;this&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;pendingRequests&lt;/span&gt;, &lt;span style=&quot;color: #aaa0fa;&quot;&gt;msg&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;id&lt;/span&gt;, &lt;span style=&quot;color: #82d2ce;&quot;&gt;new&lt;/span&gt; &lt;span style=&quot;color: #87c3ff;&quot;&gt;Error&lt;/span&gt;(&lt;span style=&quot;color: #aaa0fa;&quot;&gt;errorMsg&lt;/span&gt;))) {&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;return&lt;/span&gt;;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; } &lt;span style=&quot;color: #82d2ce;&quot;&gt;else&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #ebc88d;&quot;&gt;resolvePendingGatewayRequest&lt;/span&gt;(&lt;span style=&quot;color: #cc7c8a;&quot;&gt;this&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;pendingRequests&lt;/span&gt;, &lt;span style=&quot;color: #aaa0fa;&quot;&gt;msg&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;id&lt;/span&gt;, &lt;span style=&quot;color: #aaa0fa;&quot;&gt;msg&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;payload&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;??&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;msg&lt;/span&gt;)) {&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;        // 响应回来后再按 id 找回来,唤醒 rpc() 发送请求时登记到 pendingRequests 的 Promise&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;return&lt;/span&gt;;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;font color=&quot;#e4e4e4&quot; style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre;&quot;&gt;    &lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228); line-height: 19px;&quot;&gt;    // case2: 某个“事件”：&lt;span style=&quot;font-style: italic;&quot;&gt;type: &quot;event&quot;： &lt;/span&gt;服务端openclaw 主动推送的事件&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #aaa0fa;&quot;&gt;msg&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;type&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;===&lt;/span&gt; &lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;event&#39;&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;amp;&amp;amp;&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;typeof&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;msg&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;event&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;===&lt;/span&gt; &lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;string&#39;&lt;/span&gt;) {&lt;/div&gt;&lt;div&gt;      // 事件分发：&lt;code data-start=&quot;1358&quot; data-end=&quot;1386&quot;&gt;把 WebSocket 上收到的协议事件&lt;/code&gt;&lt;span style=&quot;font-style: italic;&quot;&gt;event&lt;/span&gt;，转成 主进程内部可监听的事件&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #ebc88d;&quot;&gt;dispatchProtocolEvent&lt;/span&gt;(&lt;span style=&quot;color: #cc7c8a;&quot;&gt;this&lt;/span&gt;, &lt;span style=&quot;color: #aaa0fa;&quot;&gt;msg&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;event&lt;/span&gt;, &lt;span style=&quot;color: #aaa0fa;&quot;&gt;msg&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;payload&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;return&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #cc7c8a;&quot;&gt;this&lt;/span&gt;.&lt;span style=&quot;color: #efb080;&quot;&gt;emit&lt;/span&gt;(&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;message&#39;&lt;/span&gt;, &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;message&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;&amp;nbsp; }&lt;/div&gt;&lt;/div&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
