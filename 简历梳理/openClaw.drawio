        <mxCell id="CriP8Mpn-Im69xwzzEPo-6" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;div style=&quot;background-color: rgb(24, 24, 24); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-weight: normal; font-size: 14px; line-height: 19px; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; //  UI 的“前端状态机”： &lt;/span&gt;按 &lt;code data-start=&quot;2109&quot; data-end=&quot;2116&quot;&gt;state&lt;/code&gt; 分流&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;div style=&quot;line-height: 19px;&quot;&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;export&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;useChatStore&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #ebc88d;&quot;&gt;create&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: #efb080;&quot;&gt;ChatState&lt;/span&gt;&amp;gt;((&lt;span style=&quot;color: #efb080;font-weight: bold;&quot;&gt;set&lt;/span&gt;, &lt;span style=&quot;color: #efb080;font-weight: bold;&quot;&gt;get&lt;/span&gt;) &lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt; ({&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); line-height: 19px;&quot;&gt;  ...&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); line-height: 19px;&quot;&gt;  // actions 方法&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #efb080;font-weight: bold;&quot;&gt;  handleChatEvent&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;event&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&q