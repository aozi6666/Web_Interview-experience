        <mxCell id="a9aXCp_dXYef1YsQoRbn-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;这里的&lt;br&gt;&lt;/font&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; white-space: pre; background-color: rgb(24, 24, 24);&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;gatewayManager&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: rgb(239, 176, 128);&quot;&gt;emit&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: rgb(227, 148, 220);&quot;&gt;&#39;chat:message&#39;&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;, { &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;message&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221); font-style: italic;&quot;&gt;payload&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; });&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; white-space: pre; background-color: rgb(24, 24, 24);&quot;&gt;gatewayManager&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; white-space: pre; background-color: rgb(24, 24, 24);&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; white-space: pre; background-color: rgb(24, 24, 24); color: rgb(239, 176, 128);&quot;&gt;emit&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; white-space: pre; background-color: rgb(24, 24, 24);&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; white-space: pre; background-color: rgb(24, 24, 24); color: rgb(227, 148, 220);&quot;&gt;&#39;chat:message&#39;&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; white-space: pre; background-color: rgb(24, 24, 24);&quot;&gt;, { &lt;/span&gt;&lt;span style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; white-space: pre; background-color: rgb(24, 24, 24); color: rgb(170, 160, 250);&quot;&gt;message&lt;/span&gt;&lt;span style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; white-space: pre; background-color: rgb(24, 24, 24); color: rgb(214, 214, 221);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; white-space: pre; background-color: rgb(24, 24, 24);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; white-space: pre; background-color: rgb(24, 24, 24); color: rgb(170, 160, 250);&quot;&gt;chatEvent&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; white-space: pre; background-color: rgb(24, 24, 24);&quot;&gt; });&lt;/span&gt;&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;会有两个监听器 gatewayManager.on 处理&lt;br&gt;1.&amp;nbsp;SSE&lt;/font&gt;&lt;br&gt;2.&amp;nbsp;&lt;font size=&quot;3&quot;&gt;UI&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="580" x="130" y="2530" as="geometry" />
        </mxCell>
        <UserObject label="&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;function&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #efb080;font-weight: bold;&quot;&gt;registerGatewayHandlers&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;(&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;gatewayManager&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;GatewayManager&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;mainWindow&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;BrowserWindow&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;): &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;void&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;type&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;GatewayHttpProxyRequest&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; = {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;path&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;?