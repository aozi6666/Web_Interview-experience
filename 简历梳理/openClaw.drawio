&quot;color: #d6d6dd;font-style: italic;&quot;&gt;eventName&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;listener&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;  // SSE 的订阅 / 退订模式&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;return&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; () &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;source&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;removeEventListener&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;eventName&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;listener&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; };&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="1080" width="520" x="-2200" y="1710" as="geometry" />
        </mxCell>
        <mxCell id="a9aXCp_dXYef1YsQoRbn-19" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;/**&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;&amp;nbsp;* Gateway State Store&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;&amp;nbsp;* Uses Host API + SSE for lifecycle/status and a direct renderer WebSocket for runtime RPC.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;&amp;nbsp;*/&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;import&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; { &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;create&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; } &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;from&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;zustand&#39;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;import&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; { &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;subscribeHostEvent&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; } &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;from&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;@/lib/host-events&#39;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;import&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;type&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; { &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;GatewayStatus&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; } &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;from&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;../types/gateway&#39;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;let&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;gatewayInitPromise&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;Promise&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;void&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;|&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;null&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; null;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;let&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;gatewayEventUnsubscribers&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;Array&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;lt;() &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;void&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;|&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;null&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; null;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;&lt;br&gt;&lt;/div&gt;// 创建一个 Gateway 状态仓库&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;export&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;useGatewayStore&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;create&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;GatewayState&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;gt;((&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;set&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;get&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;) &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; ({&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;  // 1）状态&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;status:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;state:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;stopped&#39;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;port:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;18789&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; },&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;health:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; null,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;isInitialized:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; false,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;lastError:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; null,&lt;/span&gt;&lt;/div&gt;  &lt;/div&gt;&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;  // 2）actions 方法&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;init&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;async&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; () &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;get&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;().&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;isInitialized&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;) &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;return&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;gatewayInitPromise&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;) {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;await&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;gatewayInitPromise&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;return&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; }&lt;/span&gt;&lt;/div&gt;    &lt;/div&gt;&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;     // 订阅Host事件，然后把 事件event 转成 前端状态更新&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;gatewayInitPromise&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;async&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; () &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;try&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;status&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;await&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;hostApiFetch&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;GatewayStatus&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;/api/gateway/status&#39;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;set&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;({ &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;status&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;isInitialized:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; true });&lt;/span&gt;&lt;/div&gt;         &lt;/div&gt;&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;         // &lt;code data-start=&quot;1274&quot; data-end=&quot;1286&quot;&gt;gateway.ts&lt;/code&gt; 初始化时，订阅 subscribeHostEvent(...) on持续事件&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;!&lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;gatewayEventUnsubscribers&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;) {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;unsubscribers&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;Array&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;lt;() &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;void&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;[]&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;          ... &lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; // 1. gateway:chat-message 事件&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;unsubscribers&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;push&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;subscribeHostEvent&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;gateway:chat-message&#39;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, (&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;payload&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;) &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;            // &lt;/span&gt;主进程推来 &lt;code data-start=&quot;3571&quot; data-end=&quot;3593&quot;&gt;gateway:chat-message, 触发 handleGatewayChatMessage(payload) 回调&lt;/code&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;handleGatewayChatMessage&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;payload&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }));&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;           &lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;          // 2. &lt;/span&gt;gateway:notification 事件&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;         &lt;/span&gt;&amp;nbsp;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;unsubscribers&lt;/span&gt;.&lt;span style=&quot;color: rgb(239, 176, 128);&quot;&gt;push&lt;/span&gt;(&lt;span style=&quot;color: rgb(235, 200, 141);&quot;&gt;subscribeHostEvent&lt;/span&gt;&amp;lt;{ &lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;method&lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;?&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;string&lt;/span&gt;; &lt;span style=&quot;color: rgb(170, 160, 250);&quot;&g