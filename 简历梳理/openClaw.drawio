        <mxCell id="a9aXCp_dXYef1YsQoRbn-14" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#d79b00;fillColor=#ffe6cc;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;ipcRenderer.invoke(...)&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;b&gt;&lt;font size=&quot;3&quot;&gt;请求-响应模式&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot; style=&quot;&quot;&gt;&lt;b&gt;window.electron.ipcRenderer.invoke(&#39;gateway:rpc&#39;, method, params)&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;3&quot;&gt;前端主动发起一次请求给主进程，&lt;br&gt;主进程处理完，再返回一个结果。&lt;b&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;li data-start=&quot;797&quot; data-end=&quot;809&quot;&gt;&lt;p data-start=&quot;799&quot; data-end=&quot;809&quot;&gt;&lt;font size=&quot;3&quot;&gt;前端：我问你一个问题&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;810&quot; data-end=&quot;822&quot;&gt;&lt;p data-start=&quot;812&quot; data-end=&quot;822&quot;&gt;&lt;font size=&quot;3&quot;&gt;主进程：我算完答复你&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;823&quot; data-end=&quot;841&quot;&gt;&lt;p data-start=&quot;825&quot; data-end=&quot;841&quot;&gt;&lt;font size=&quot;3&quot;&gt;前端：拿到 Promise 结果&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="530" x="-1010" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="a9aXCp_dXYef1YsQoRbn-15" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;i&lt;/font&gt;&lt;/b&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;&lt;b&gt;pcRenderer.on(...)&lt;/b&gt;&lt;/span&gt;&lt;div&gt;&lt;b&gt;&lt;font size=&quot;3&quot;&gt;主进程主动推送消息 - 配合监听器&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;b&gt;window.electron.ipcRenderer.on(&#39;gateway:chat-message&#39;, handler)&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;前端先注册一个监听器，站在这里等。&lt;br data-start=&quot;1075&quot; data-end=&quot;1078&quot;&gt;&lt;br/&gt;以后只要主进程往这个 channel 发消息，我就执行 handler。&lt;/div&gt;&lt;div&gt;&lt;li data-start=&quot;797&quot; data-end=&quot;809&quot;&gt;&lt;p data-start=&quot;799&quot; data-end=&quot;809&quot;&gt;&lt;font size=&quot;3&quot;&gt;前端：我问你一个问题&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;810&quot; data-end=&quot;822&quot;&gt;&lt;p data-start=&quot;812&quot; data-end=&quot;822&quot;&gt;&lt;font size=&quot;3&quot;&gt;主进程：我算完答复你&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;823&quot; data-end=&quot;841&quot;&gt;&lt;p data-start=&quot;825&quot; data-end=&quot;841&quot;&gt;&lt;font size=&quot;3&quot;&gt;前端：拿到 Promise 结果&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/div&gt;" vertex="1">
