gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;number&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; };&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;  ...&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;// Forward Gateway events to renderer&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;gatewayManager&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;on&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;message&#39;&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;, (&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;message&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;) &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; (!&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;mainWindow&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;isDestroyed&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;()) {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;      // &lt;/span&gt;主进程 &lt;code data-start=&quot;32&quot; data-end=&quot;50&quot;&gt;webContents.send&lt;/code&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;mainWindow&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;webContents&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;send&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;gateway:message&#39;&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;message&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &amp;nbsp; }&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; });&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;gatewayManager&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;on&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;chat:message&#39;&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;, (&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;data&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;) &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; (!&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;mainWindow&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;isDestroyed&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;()) {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;      // 把主进程里的事件，发给 renderer 窗口&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;mainWindow&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;webContents&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;send&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;gateway:chat-message&#39;&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;data&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; &amp;nbsp; }&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp; });&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" link="&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;function&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #efb080;font-weight: 