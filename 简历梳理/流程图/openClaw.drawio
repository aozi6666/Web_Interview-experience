          <mxGeometry height="30" width="100" x="1700" as="geometry" />
        </mxCell>
        <mxCell id="1nMDwmI68g-W47vcw8KW-14" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;ClawX/electron/main/ipc-handlers.ts&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="260" x="1640" y="130" as="geometry" />
