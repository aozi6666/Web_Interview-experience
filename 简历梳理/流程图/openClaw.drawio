        <mxCell id="1nMDwmI68g-W47vcw8KW-31" parent="1" style="text;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;rounded=0;fillColor=#333333;" value="&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;// 应用层 握手成功时触发&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(239, 176, 128); font-weight: bold;&quot;&gt;resolveOnce&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; () &lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;if&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: rgb(135, 195, 255);&quot;&gt;settled&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;) &lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;return&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(135, 195, 255);&quot;&gt;settled&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; true;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(235, 200, 141);&quot;&gt;cleanupHandshakeRequest&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;();&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;      // resolve通过连接的 ws 对象&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(235, 200, 141);&quot;&gt;resolve&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;ws&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; };&lt;/span&gt;&lt;/div&gt;" vertex="1">
