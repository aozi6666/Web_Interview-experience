        <mxCell id="q1YqlvR1EvPMMT2ad3zU-4" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;div style=&quot;background-color: rgb(24, 24, 24); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-weight: normal; font-size: 14px; line-height: 19px; white-space: pre; color: rgb(228, 228, 228);&quot;&gt;&lt;div style=&quot;line-height: 19px;&quot;&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;MessageList&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #efb080;&quot;&gt;React&lt;/span&gt;.&lt;span style=&quot;color: #efb080;&quot;&gt;FC&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: #efb080;&quot;&gt;MessageListProps&lt;/span&gt;&amp;gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; ({&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;messages&lt;/span&gt;,&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;session&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; null,&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;assistantName&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;AI 助手&#39;&lt;/span&gt;,&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &lt;span style=&quot;color: #efb080;font-weight: bold;&quot;&gt;onPlayStart&lt;/span&gt;,&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &lt;span style=&quot;color: #efb080;font-weight: bold;&quot;&gt;onPlayEnd&lt;/span&gt;,&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &lt;span style=&quot;color: #efb080;font-weight: bold;&quot;&gt;onLog&lt;/span&gt;,&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;isInterrupting&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; false,&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;className&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;&#39;&lt;/span&gt;,&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;}) &lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;messageContainerRef&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #ebc88d;&quot;&gt;useRef&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;HTMLDivElement&lt;/span&gt;&amp;gt;(null);&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &lt;br&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;font color=&quot;#e4e4e4&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &lt;span style=&quot;font-style: italic;&quot;&gt;// &amp;nbsp;滚动逻辑优化:&lt;/span&gt;每来一次新消息，就检查一次“要不要自动滚到底部”&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &lt;span style=&quot;color: #ebc88d;&quot;&gt;useEffect&lt;/span&gt;(() &lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;    // 等页面渲染好，确保拿到真实 DOM（div）&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;    // 才有 真实 DOM 元素的 scrollTop、scrollHeight、clientHeight属性和 scrollTo()方法&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #d6d6dd;&quot;&gt;!&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;messageContainerRef&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;current&lt;/span&gt;) &lt;span style=&quot;color: #82d2ce;&quot;&gt;return&lt;/span&gt;;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;    // 真正的滚动容器：container&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;container&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;messageContainerRef&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;current&lt;/span&gt;;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;    // 算 距离底部 还差多少&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;distanceToBottom&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;container&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;scrollHeight&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;-&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;container&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;scrollTop&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;-&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;container&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;clientHeight&lt;/span&gt;;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;    // 自动滚动实现：低于 底部缓冲区 “阈值” ：认为用户 没有查看 上面的历史消息，可以忍受自动滚动&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;    if&lt;/span&gt; (&lt;span style=&quot;color: #aaa0fa;&quot;&gt;distanceToBottom&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;lt;&lt;/span&gt; &lt;span style=&quot;color: #ebc88d;&quot;&gt;150&lt;/span&gt;) {&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;     // 等浏览器把这次页面更新真正画出来之后，再去滚动。&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #ebc88d;&quot;&gt;requestAnimationFrame&lt;/span&gt;(() &lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #aaa0fa;&quot;&gt;messageContainerRef&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;current&lt;/span&gt;) {&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;font-style: italic;&quot;&gt;// 使用 scrollTo 方法实现平滑滚动&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;messageContainerRef&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;current&lt;/span&gt;.&lt;span style=&quot;color: #efb080;&quot;&gt;scrollTo&lt;/span&gt;({&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;top&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;messageContainerRef&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;current&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;scrollHeight&lt;/span&gt;,&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;behavior&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;smooth&#39;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; });&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; });&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; }, &lt;span style=&quot;color: #d6d6dd;&quot;&gt;[&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;messages&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;]&lt;/span&gt;);&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;font color=&quot;#e4e4e4&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;return&lt;/span&gt; (&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #a4a4a4;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #fad075;&quot;&gt;div&lt;/span&gt;&lt;span style=&quot;color: #fad075;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;font-style: italic;&quot;&gt;className&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;{&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;`message-list-layout w-full h-full &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;${&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;className&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;}&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;`&lt;/span&gt;&lt;span style=&quot;color: #fad075;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;trim&lt;/span&gt;&lt;span style=&quot;color: #fad075;&quot;&gt;()&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;}&lt;/span&gt;&lt;span style=&quot;color: #a4a4a4;&quot;&gt;&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;// 把这个 div 节点，交给 messageContainerRef 来引用（真实的 DOM 元素的 “遥控器”）&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;// 页面渲染完成后，messageContainerRef.current 拿到是这个真正的 DOM&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #fad075;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #a4a4a4;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #fad075;&quot;&gt;div&lt;/span&gt;&lt;span style=&quot;color: #fad075;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;font-style: italic;&quot;&gt;ref&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;{&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;messageContainerRef&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;}&lt;/span&gt;&lt;span style=&quot;color: #fad075;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;font-style: italic;&quot;&gt;className&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&quot;message-list-container&quot;&lt;/span&gt;&lt;span style=&quot;color: #a4a4a4;&quot;&gt;&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;color: rgb(250, 208, 117);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(250, 208, 117);&quot;&gt;&lt;font color=&quot;#82d2ce&quot;&gt;...&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #fad075;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #a4a4a4;&quot;&gt;&amp;lt;/&lt;/span&gt;&lt;span style=&quot;color: #fad075;&quot;&gt;div&lt;/span&gt;&lt;span style=&quot;color: #a4a4a4;&quot;&gt;&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;color: #fad075;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #a4a4a4;&quot;&gt;&amp;lt;/&lt;/span&gt;&lt;span style=&quot;color: #fad075;&quot;&gt;div&lt;/span&gt;&lt;span style=&quot;color: #a4a4a4;&quot;&gt;&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; );&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228);&quot;&gt;};&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="2530" width="800" x="260" y="180" as="geometry" />
        </mxCell>
        <mxCell id="q1YqlvR1EvPMMT2ad3zU-6" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #f8c762;&quot;&gt;.message-list-container&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;width&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;100%&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;height&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;100%&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;overflow-y&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;auto&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;overflow-x&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;hidden&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;padding&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;16px&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;box-sizing&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;border-box&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;/* 所有滚动行为默认平滑 */&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;scroll-behavior&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;smooth&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
