          <mxGeometry height="150" width="480" x="1150" y="730" as="geometry" />
        </mxCell>
        <mxCell id="qc8tz0Ly24j66dD8AOWT-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#d79b00;fillColor=#ffe6cc;align=center;verticalAlign=middle;rounded=0;" value="&lt;p data-start=&quot;1791&quot; data-end=&quot;1809&quot; style=&quot;text-align: left;&quot;&gt;&lt;code data-start=&quot;1795&quot; data-end=&quot;1805&quot;&gt;messages&lt;/code&gt; 变化&amp;nbsp; ——&amp;gt;&amp;nbsp;&lt;code data-start=&quot;1886&quot; data-end=&quot;1897&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center;&quot;&gt;useEffect&lt;/code&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center;&quot;&gt;就跑一次&lt;/span&gt;&lt;/p&gt;&lt;ul data-start=&quot;1816&quot; data-end=&quot;1864&quot;&gt;&lt;li data-start=&quot;1816&quot; data-end=&quot;1827&quot;&gt;&lt;p data-start=&quot;1818&quot; data-end=&quot;1827&quot; style=&quot;text-align: left;&quot;&gt;用户发了一条新消息&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;1828&quot; data-end=&quot;1842&quot;&gt;&lt;p data-start=&quot;1830&quot; data-end=&quot;1842&quot; style=&quot;text-align: left;&quot;&gt;AI 回复新增了一段内容&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;1843&quot; data-end=&quot;1864&quot;&gt;&lt;p data-start=&quot;1845&quot; data-end=&quot;1864&quot; style=&quot;text-align: left;&quot;&gt;流式输出时，answer 内容不断更新&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
