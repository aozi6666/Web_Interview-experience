 rgb(220, 220, 170);&quot;&gt;reject&lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: rgb(79, 193, 255);&quot;&gt;tx&lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: rgb(79, 193, 255);&quot;&gt;error&lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204); font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;    };&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204); font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;  });&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204); font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: left; white-space: pre;&quot;&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;}&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="600" width="780" x="1990" y="13145" as="geometry" />
        </mxCell>
        <mxCell id="Mxlbeqx_feKBjcEV_gw4-8" parent="1" style="text;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;rounded=0;" value="&lt;div class=&quot;lake-content&quot;&gt;&lt;pre data-language=&quot;vue&quot; id=&quot;wN0e4&quot; class=&quot;ne-codeblock language-vue&quot; style=&quot;border: 1px solid rgb(232, 232, 232); border-radius: 2px; background: rgb(249, 249, 249); padding: 16px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font&gt;&lt;span style=&quot;font-size: 13px;&quot;&gt;&lt;font color=&quot;#595959&quot;&gt;import { useState, useCallback, useRef, useTransition } from &#39;react&#39;;&lt;br&gt;import { Message, MessageType } from &#39;../types/message&#39;;&lt;br&gt;import { addMessage as dbAddMessage, updateMessage as dbUpdateMessage } from &#39;../utils/conversationDb&#39;;&lt;br&gt;&lt;br&gt;/**&lt;br&gt; * 消息管理相关的状态和逻辑&lt;br&gt; */&lt;br&gt;export const useMessages = (currentConversationIdRef: React.MutableRefObject&amp;lt;string | null&amp;gt;): UseMessagesReturn =&amp;gt; {&lt;br&gt;  // （右侧聊天窗口）当前显示的消息 列表&lt;br&gt;  const [messages, setMessages] = useState&amp;lt;Message[]&amp;gt;([]);&lt;br&gt;  &lt;br&gt;  &lt;br&gt;  // 记住 当前 AI 正在输出的那条消息 id&lt;br&gt;  const currentAIMessageIdRef = useRef&amp;lt;string | null&amp;gt;(null);&lt;br&gt;  // 当前AI回复的roundId（用于判断是否是新的回复）&lt;br&gt;  const currentRoundIdRef = useRef&amp;lt;number | null&amp;gt;(null);&lt;br&gt;  // 流式内容累计Map：为每个messageId维护 独立的streamContent流式累计内容（防止Chunk被覆盖）&lt;br&gt;  const streamContentMapRef = useRef&amp;lt;Map&amp;lt;string, string&amp;gt;&amp;gt;(new Map());&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font&gt;&lt;span style=&quot;font-size: 13px;&quot;&gt;&lt;font color=&quot;#595959&quot;&gt;&lt;br&gt;&lt;br&gt;  // 添加 “消息” 到消息列表，返回完整消息对象（便于持久化到历史）&lt;br&gt;  // 新建一条消息，先放进 React 页面状态里，再写入 IndexedDB&lt;br&gt;  const addMessage = useCallback((&lt;br&gt;    type: MessageType,&lt;br&gt;    content: string,&lt;br&gt;    status?: Message[&#39;status&#39;],&lt;br&gt;    imageUrl?: string,&lt;br&gt;    imageName?: string,&lt;br&gt;    assistantNameOverride?: string&lt;br&gt;  ): Message =&amp;gt; {&lt;br&gt;    // 1. 生成 消息id (随机数+时间戳)&lt;br&gt;    const now = new Date().toISOString();&lt;br&gt;    const messageId = `msg_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;&lt;br&gt;    // 2. 组装成完整 Message 对象&lt;br&gt;    const newMessage: Message = {&lt;br&gt;      id: messageId,&lt;br&gt;      content,&lt;br&gt;      type,&lt;br&gt;      status,&lt;br&gt;      createdAt: now,&lt;br&gt;      updatedAt: now,&lt;br&gt;      ...(assistantNameOverride &amp;amp;&amp;amp; { assistantName: assistantNameOverride }),  // assistant 助手名字覆盖&lt;br&gt;      ...(imageUrl &amp;amp;&amp;amp; { imageUrl }),   // 图片消息字段&lt;br&gt;      ...(imageName &amp;amp;&amp;amp; { imageName }),  // 图片消息字段&lt;br&gt;    };&lt;br&gt;    &lt;/font&gt;&lt;font style=&quot;color: rgb(255, 85, 12);&quot;&gt;// &lt;b style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(89, 13, 1);&quot;&gt;3. 更新 React state（让页面立刻显示 最新消息）&lt;/font&gt;&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#595959&quot;&gt;&lt;br&gt;    setMessages((prev) =&amp;gt; [...prev, newMessage]);&lt;br&gt;    &lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font&gt;&lt;span style=&quot;font-size: 13px;&quot;&gt;&lt;font color=&quot;#595959&quot;&gt;    // 4. 同步写入 IndexedDB&lt;br&gt;    // 1）先从 ref 里拿当前 会话id&lt;br&gt;    const cid = currentConversationIdRef.current;&lt;br&gt;    if (cid) {&lt;br&gt;      // &lt;/font&gt;&lt;font style=&quot;color: rgb(255, 55, 5);&quot;&gt;&lt;b&gt;调用底层 数据库层的 addMessage 方法，把这条消息写进 IndexedDB&lt;/b&gt;&lt;/font&gt;&lt;font color=&quot;#595959&quot;&gt;&lt;br&gt;      dbAddMessage(cid, newMessage).catch(&lt;br&gt;&#x9;(err) =&amp;gt; console.warn(&#39;[conversationDb] addMessage failed:&#39;, err));&lt;br&gt;    }&lt;br&gt;    return newMessage;&lt;br&gt;  }, [currentConversationIdRef]);&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(89, 89, 89); text-align: left;&quot;&gt;&lt;font color=&quot;#595959&quot;&gt;&lt;span style=&quot;font-size: 13px;&quot;&gt;   &lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(89, 89, 89); text-align: left;&quot;&gt;&lt;font color=&quot;#595959&quot;&gt;&lt;span style=&quot;font-size: 13px;&quot;&gt;  ... &lt;br&gt;&lt;br&gt;  &lt;br&gt;  // 这轮临时缓存清掉（Map清空，不污染下一轮）&lt;br&gt;  const clearStreamContent = useCallback(() =&amp;gt; {&lt;br&gt;    currentAIMessageIdRef.current = null;&lt;br&gt;    currentRoundIdRef.current = null;&lt;br&gt;    // 这轮临时缓存清掉&lt;br&gt;    streamContentMapRef.current.clear();&lt;br&gt;  }, []);&lt;br&gt;&lt;br&gt;  return {&lt;br&gt;    messages,&lt;br&gt;    addMessage,&lt;br&gt;    setMessages,&lt;br&gt;    currentConversationIdRef,&lt;br&gt;    currentAIMessageIdRef,&lt;br&gt;    currentRoundIdRef,&lt;br&gt;    streamContentMapRef,&lt;br&gt;    clearStreamContent,&lt;br&gt;  };&lt;br&gt;};&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/pre&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="1280" width="960" x="920" y="12804" as="geometry" />
        </mxCell>
