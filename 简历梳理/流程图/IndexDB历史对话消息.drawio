        <mxCell id="bxZO6ae0OLCbubPqrkJh-79" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;div style=&quot;background-color: rgb(31, 31, 31); font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; font-weight: normal; font-size: 14px; line-height: 21px; white-space: pre; color: rgb(204, 204, 204);&quot;&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;&lt;span style=&quot;color: rgb(86, 156, 214);&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: rgb(79, 193, 255);&quot;&gt;App&lt;/span&gt;&lt;span style=&quot;color: rgb(212, 212, 212);&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: rgb(78, 201, 176);&quot;&gt;React&lt;/span&gt;.&lt;span style=&quot;color: rgb(78, 201, 176);&quot;&gt;FC&lt;/span&gt; &lt;span style=&quot;color: rgb(212, 212, 212);&quot;&gt;=&lt;/span&gt; () &lt;span style=&quot;color: rgb(86, 156, 214);&quot;&gt;=&amp;gt;&lt;/span&gt; {  &lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;  ...&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;  return&lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt; (&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color: #808080;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;div&lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;className&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #ce9178;&quot;&gt;&quot;app-container&quot;&lt;/span&gt;&lt;span style=&quot;color: #808080;&quot;&gt;&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;font color=&quot;#cccccc&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;        &lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;{&lt;/span&gt;&lt;span style=&quot;color: #6a9955;&quot;&gt;/* 可滚动内容区 */&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;        &lt;/span&gt;&lt;span style=&quot;color: #808080;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;div&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;className&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #ce9178;&quot;&gt;&quot;content-scrollable&quot;&lt;/span&gt;&lt;span style=&quot;color: #808080;&quot;&gt;&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #808080;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;    ...&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;        &lt;/span&gt;&lt;span style=&quot;color: #808080;&quot;&gt;&amp;lt;/&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;div&lt;/span&gt;&lt;span style=&quot;color: #808080;&quot;&gt;&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;font color=&quot;#cccccc&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;        &lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;{&lt;/span&gt;&lt;span style=&quot;color: #6a9955;&quot;&gt;/* 消息输入区域：MessageInput 组件（布局方案说明） */&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;        &lt;/span&gt;&lt;span style=&quot;color: #808080;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;MessageInput&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;color: rgb(212, 212, 212);&quot;&gt;          &lt;/span&gt;&lt;span style=&quot;color: rgb(212, 212, 212);&quot;&gt;&lt;font color=&quot;#9cdcfe&quot;&gt;...&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;          &lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;onSend&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;{&lt;/span&gt;&lt;span style=&quot;color: #dcdcaa;&quot;&gt;handleSend&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;          &lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;disabled&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;{&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;!&lt;/span&gt;&lt;span style=&quot;color: #4fc1ff;&quot;&gt;isConnected&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;          &lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;placeholder&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #ce9178;&quot;&gt;&quot;输入文本发送给 AI（演示）&quot;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;          &lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;voiceInputDisabled&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;{&lt;/span&gt;&lt;span style=&quot;color: #4fc1ff;&quot;&gt;micMuted&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;        &lt;/span&gt;&lt;span style=&quot;color: #808080;&quot;&gt;/&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color: #808080;&quot;&gt;&amp;lt;/&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;div&lt;/span&gt;&lt;span style=&quot;color: #808080;&quot;&gt;&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;  );&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;}&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="460" width="637" x="733" y="12200" as="geometry" />
        </mxCell>
        <mxCell id="bxZO6ae0OLCbubPqrkJh-80" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;三、组件 与 自定义Hook 配合&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="380" x="30" y="12180" as="geometry" />
        </mxCell>
        <UserObject label="&lt;div style=&quot;background-color: rgb(31, 31, 31); font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; font-weight: normal; font-size: 14px; line-height: 21px; white-space: pre; color: rgb(204, 204, 204);&quot;&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;&lt;span style=&quot;color: rgb(86, 156, 214);&quot;&gt;&lt;div style=&quot;color: rgb(204, 204, 204); line-height: 21px;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;import &lt;span style=&quot;color: #9cdcfe;&quot;&gt;React&lt;/span&gt;, { &lt;span style=&quot;color: #9cdcfe;&quot;&gt;useState&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;useEffect&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;useRef&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;useCallback&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;useMemo&lt;/span&gt; } from &lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;react&#39;&lt;/span&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;import&lt;/span&gt; { &lt;span style=&quot;color: #9cdcfe;&quot;&gt;useConversations&lt;/span&gt; } &lt;span style=&quot;color: #c586c0;&quot;&gt;from&lt;/span&gt; &lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;./hooks/useConversations&#39;&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;import&lt;/span&gt; { &lt;span style=&quot;color: #9cdcfe;&quot;&gt;useMessages&lt;/span&gt; } &lt;span style=&quot;color: #c586c0;&quot;&gt;from&lt;/span&gt; &lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;./hooks/useMessages&#39;&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;&lt;span style=&quot;color: rgb(86, 156, 214);&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: rgb(79, 193, 255);&quot;&gt;App&lt;/span&gt;&lt;span style=&quot;color: rgb(212, 212, 212);&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: rgb(78, 201, 176);&quot;&gt;React&lt;/span&gt;.&lt;span style=&quot;color: rgb(78, 201, 176);&quot;&gt;FC&lt;/span&gt; &lt;span style=&quot;color: rgb(212, 212, 212);&quot;&gt;=&lt;/span&gt; () &lt;span style=&quot;color: rgb(86, 156, 214);&quot;&gt;=&amp;gt;&lt;/span&gt; {  &lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;  &lt;span style=&quot;color: rgb(106, 153, 85);&quot;&gt;// 当前对话 ID（用于消息与历史联动）&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;  &lt;span style=&quot;color: rgb(86, 156, 214);&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: rgb(79, 193, 255);&quot;&gt;currentConversationIdRef&lt;/span&gt; &lt;span style=&quot;color: rgb(212, 212, 212);&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: rgb(220, 220, 170);&quot;&gt;useRef&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: rgb(78, 201, 176);&quot;&gt;string&lt;/span&gt; &lt;span style=&quot;color: rgb(212, 212, 212);&quot;&gt;|&lt;/span&gt; &lt;span style=&quot;color: rgb(78, 201, 176);&quot;&gt;null&lt;/span&gt;&amp;gt;(&lt;span style=&quot;color: rgb(86, 156, 214);&quot;&gt;null&lt;/span&gt;);&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;  &lt;span style=&quot;color: rgb(86, 156, 214);&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: rgb(79, 193, 255);&quot;&gt;configRef&lt;/span&gt; &lt;span style=&quot;color: rgb(212, 212, 212);&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: rgb(220, 220, 170);&quot;&gt;useRef&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: rgb(78, 201, 176);&quot;&gt;ReturnType&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: rgb(86, 156, 214);&quot;&gt;typeof&lt;/span&gt; &lt;span style=&quot;color: rgb(156, 220, 254);&quot;&gt;AgentConfig&lt;/span&gt;.&lt;span style=&quot;color: rgb(156, 220, 254);&quot;&gt;Create&lt;/span&gt;&amp;gt; &lt;span style=&quot;color: rgb(212, 212, 212);&quot;&gt;|&lt;/span&gt; &lt;span style=&quot;color: rgb(78, 201, 176);&quot;&gt;null&lt;/span&gt;&amp;gt;(&lt;span style=&quot;color: rgb(86, 156, 214);&quot;&gt;null&lt;/span&gt;);&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;  // AI 相关&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;div style=&quot;line-height: 21px;&quot;&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;  const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;sessionRef&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useRef&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;Session&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;|&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;null&lt;/span&gt;&amp;gt;(&lt;span style=&quot;color: #569cd6;&quot;&gt;null&lt;/span&gt;);&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;div style=&quot;line-height: 21px;&quot;&gt;&lt;div&gt;  &lt;/div&gt;&lt;div&gt;  // 从自定义Hook 取变量/处理函数&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(86, 156, 214);&quot;&gt;  const&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;     &lt;span style=&quot;color: rgb(79, 193, 255);&quot;&gt;messages&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;     &lt;span style=&quot;color: rgb(220, 220, 170);&quot;&gt;addMessage&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;     &lt;span style=&quot;color: rgb(79, 193, 255);&quot;&gt;currentAIMessageIdRef&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;     &lt;span style=&quot;color: rgb(79, 193, 255);&quot;&gt;currentRoundIdRef&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;     &lt;span style=&quot;color: rgb(79, 193, 255);&quot;&gt;streamContentMapRef&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;     &lt;span style=&quot;color: rgb(220, 220, 170);&quot;&gt;clearStreamContent&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    } &lt;span style=&quot;color: rgb(212, 212, 212);&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: rgb(220, 220, 170);&quot;&gt;useMessages&lt;/span&gt;(&lt;span style=&quot;color: rgb(79, 193, 255);&quot;&gt;currentConversationIdRef&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;  // 从自定义Hook 取变量/处理函数&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;line-height: 21px;&quot;&gt;&lt;div&gt;  &lt;span style=&quot;color: rgb(86, 156, 214);&quot;&gt;const&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;     &lt;span style=&quot;color: rgb(79, 193, 255);&quot;&gt;conversations&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;     &lt;span style=&quot;color: rgb(79, 193, 255);&quot;&gt;currentConversationId&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;     &lt;span style=&quot;color: rgb(220, 220, 170);&quot;&gt;setCurrentConversationId&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;     &lt;span style=&quot;color: rgb(220, 220, 170);&quot;&gt;createNewConversation&lt;/span&gt;,&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;    } &lt;span style=&quot;color: rgb(212, 212, 212);&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: rgb(220, 220, 170);&quot;&gt;useConversations&lt;/span&gt;(&lt;span style=&quot;color: rgb(220, 220, 170);&quot;&gt;setMessages&lt;/span&gt;, &lt;span style=&quot;color: rgb(79, 193, 255);&quot;&gt;configRef&lt;/span&gt;, &lt;span style=&quot;color: rgb(79, 193, 255);&quot;&gt;currentConversationIdRef&lt;/span&gt;); &lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #6a9955;&quot;&gt;    // 回调函数：处理发送文本（支持同时发送图片和文本）&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;   &lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #dcdcaa;&quot;&gt;handleSend&lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #dcdcaa;&quot;&gt;useCallback&lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;async&lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt; () &lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;    // 获取输入框文本&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #4fc1ff;&quot;&gt;text&lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #4fc1ff;&quot;&gt;textInput&lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #dcdcaa;&quot;&gt;trim&lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;();&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;    &lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204, 204);&quot;&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color: #6a9955;&quot;&gt;// 如果没有文本也没有图片，不发送&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(204, 204