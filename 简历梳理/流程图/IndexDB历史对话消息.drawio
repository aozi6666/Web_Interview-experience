        <mxCell id="Mxlbeqx_feKBjcEV_gw4-36" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;color: rgb(204, 204, 204); background-color: rgb(31, 31, 31); font-family: Menlo, Monaco, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; line-height: 21px; white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;import&lt;/span&gt; { &lt;span style=&quot;color: #9cdcfe;&quot;&gt;useState&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;useCallback&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;useRef&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;useTransition&lt;/span&gt; } &lt;span style=&quot;color: #c586c0;&quot;&gt;from&lt;/span&gt; &lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;react&#39;&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;import&lt;/span&gt; { &lt;span style=&quot;color: #9cdcfe;&quot;&gt;Message&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;MessageType&lt;/span&gt; } &lt;span style=&quot;color: #c586c0;&quot;&gt;from&lt;/span&gt; &lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;../types/message&#39;&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;import&lt;/span&gt; { &lt;span style=&quot;color: #9cdcfe;&quot;&gt;addMessage&lt;/span&gt; &lt;span style=&quot;color: #c586c0;&quot;&gt;as&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;dbAddMessage&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;updateMessage&lt;/span&gt; &lt;span style=&quot;color: #c586c0;&quot;&gt;as&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;dbUpdateMessage&lt;/span&gt; } &lt;span style=&quot;color: #c586c0;&quot;&gt;from&lt;/span&gt; &lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;../utils/conversationDb&#39;&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;import&lt;/span&gt; { &lt;span style=&quot;color: #9cdcfe;&quot;&gt;UPDATE_INTERVAL&lt;/span&gt; } &lt;span style=&quot;color: #c586c0;&quot;&gt;from&lt;/span&gt; &lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;../constants&#39;&lt;/span&gt;;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #6a9955;&quot;&gt;/**&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #6a9955;&quot;&gt; * 消息管理相关的状态和逻辑&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #6a9955;&quot;&gt; */&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;export&lt;/span&gt; &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useMessages&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; (&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #9cdcfe;&quot;&gt;currentConversationIdRef&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;React&lt;/span&gt;.&lt;span style=&quot;color: #4ec9b0;&quot;&gt;MutableRefObject&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;|&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;null&lt;/span&gt;&amp;gt;&lt;/div&gt;&lt;div&gt;)&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;UseMessagesReturn&lt;/span&gt; &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; [&lt;span style=&quot;color: #4fc1ff;&quot;&gt;messages&lt;/span&gt;, &lt;span style=&quot;color: #dcdcaa;&quot;&gt;setMessages&lt;/span&gt;] &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useState&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;Message&lt;/span&gt;[]&amp;gt;([]);&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; [, &lt;span style=&quot;color: #dcdcaa;&quot;&gt;startMessagesTransition&lt;/span&gt;] &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useTransition&lt;/span&gt;();&lt;/div&gt;&lt;div&gt;  &lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #6a9955;&quot;&gt;// 当前AI回复的消息ID（用于流式更新）&lt;/span&gt;&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentAIMessageIdRef&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useRef&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;|&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;null&lt;/span&gt;&amp;gt;(&lt;span style=&quot;color: #569cd6;&quot;&gt;null&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #6a9955;&quot;&gt;// 当前AI回复的roundId（用于判断是否是新的回复）&lt;/span&gt;&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentRoundIdRef&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useRef&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;number&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;|&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;null&lt;/span&gt;&amp;gt;(&lt;span style=&quot;color: #569cd6;&quot;&gt;null&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #6a9955;&quot;&gt;// 流式内容累计Map：为每个messageId维护独立的streamContent（防止Chunk被覆盖）&lt;/span&gt;&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;streamContentMapRef&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useRef&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;Map&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt;, &lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt;&amp;gt;&amp;gt;(&lt;span style=&quot;color: #569cd6;&quot;&gt;new&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;Map&lt;/span&gt;());&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #6a9955;&quot;&gt;// 节流策略：记录每个消息的最后更新时间（requestAnimationFrame + 时间戳节流）&lt;/span&gt;&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;lastUpdateTimeRef&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useRef&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;Map&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt;, &lt;span style=&quot;color: #4ec9b0;&quot;&gt;number&lt;/span&gt;&amp;gt;&amp;gt;(&lt;span style=&quot;color: #569cd6;&quot;&gt;new&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;Map&lt;/span&gt;());&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;rafIdRef&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useRef&lt;/span&gt;&amp;lt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;number&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;|&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;null&lt;/span&gt;&amp;gt;(&lt;span style=&quot;color: #569cd6;&quot;&gt;null&lt;/span&gt;);&lt;/div&gt;&lt;div&gt; &lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #6a9955;&quot;&gt;// 添加消息到消息列表，返回完整消息对象（便于持久化到历史）&lt;/span&gt;&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;addMessage&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useCallback&lt;/span&gt;((&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;type&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;MessageType&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;content&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;status&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;?:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;Message&lt;/span&gt;[&lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;status&#39;&lt;/span&gt;],&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;imageUrl&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;?:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;imageName&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;?:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;assistantNameOverride&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;?:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt;&lt;/div&gt;&lt;div&gt;  )&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;Message&lt;/span&gt; &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;now&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #569cd6;&quot;&gt;new&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;Date&lt;/span&gt;().&lt;span style=&quot;color: #dcdcaa;&quot;&gt;toISOString&lt;/span&gt;();&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;messageId&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #ce9178;&quot;&gt;`msg_&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;${&lt;/span&gt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;Date&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #dcdcaa;&quot;&gt;now&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;()&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;}&lt;/span&gt;&lt;span style=&quot;color: #ce9178;&quot;&gt;_&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;${&lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;Math&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #dcdcaa;&quot;&gt;random&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;().&lt;/span&gt;&lt;span style=&quot;color: #dcdcaa;&quot;&gt;toString&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #b5cea8;&quot;&gt;36&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;).&lt;/span&gt;&lt;span style=&quot;color: #dcdcaa;&quot;&gt;substr&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #b5cea8;&quot;&gt;2&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #b5cea8;&quot;&gt;9&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;)&lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;}&lt;/span&gt;&lt;span style=&quot;color: #ce9178;&quot;&gt;`&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;newMessage&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;Message&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #9cdcfe;&quot;&gt;id&lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;messageId&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #9cdcfe;&quot;&gt;content&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #9cdcfe;&quot;&gt;type&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #9cdcfe;&quot;&gt;status&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #9cdcfe;&quot;&gt;createdAt&lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;now&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #9cdcfe;&quot;&gt;updatedAt&lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;now&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #d4d4d4;&quot;&gt;...&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;assistantNameOverride&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;amp;&amp;amp;&lt;/span&gt; { &lt;span style=&quot;color: #9cdcfe;&quot;&gt;assistantName&lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;assistantNameOverride&lt;/span&gt; }),&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #d4d4d4;&quot;&gt;...&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;imageUrl&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;amp;&amp;amp;&lt;/span&gt; { &lt;span style=&quot;color: #9cdcfe;&quot;&gt;imageUrl&lt;/span&gt; }),&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #d4d4d4;&quot;&gt;...&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;imageName&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;amp;&amp;amp;&lt;/span&gt; { &lt;span style=&quot;color: #9cdcfe;&quot;&gt;imageName&lt;/span&gt; }),&lt;/div&gt;&lt;div&gt;    };&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #dcdcaa;&quot;&gt;setMessages&lt;/span&gt;((&lt;span style=&quot;color: #9cdcfe;&quot;&gt;prev&lt;/span&gt;) &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; [&lt;span style=&quot;color: #d4d4d4;&quot;&gt;...&lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;prev&lt;/span&gt;, &lt;span style=&quot;color: #4fc1ff;&quot;&gt;newMessage&lt;/span&gt;]);&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;cid&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;currentConversationIdRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #c586c0;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #4fc1ff;&quot;&gt;cid&lt;/span&gt;) {&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #dcdcaa;&quot;&gt;dbAddMessage&lt;/span&gt;(&lt;span style=&quot;color: #4fc1ff;&quot;&gt;cid&lt;/span&gt;, &lt;span style=&quot;color: #4fc1ff;&quot;&gt;newMessage&lt;/span&gt;).&lt;span style=&quot;color: #dcdcaa;&quot;&gt;catch&lt;/span&gt;((&lt;span style=&quot;color: #9cdcfe;&quot;&gt;err&lt;/span&gt;) &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;console&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;warn&lt;/span&gt;(&lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;[conversationDb] addMessage failed:&#39;&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;err&lt;/span&gt;));&lt;/div&gt;&lt;div&gt;    }&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #c586c0;&quot;&gt;return&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;newMessage&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;  }, [&lt;span style=&quot;color: #9cdcfe;&quot;&gt;currentConversationIdRef&lt;/span&gt;]);&lt;/div&gt;&lt;br&gt;&lt;div&gt;  &lt;span style=&quot;color: #6a9955;&quot;&gt;// 更新消息内容（用于流式输出）；同时持久化到 IndexedDB&lt;/span&gt;&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;updateMessage&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useCallback&lt;/span&gt;((&lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;content&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;status&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;?:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;Message&lt;/span&gt;[&lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;status&#39;&lt;/span&gt;]) &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;updatedAt&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #569cd6;&quot;&gt;new&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;Date&lt;/span&gt;().&lt;span style=&quot;color: #dcdcaa;&quot;&gt;toISOString&lt;/span&gt;();&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #6a9955;&quot;&gt;// 使用并发模式：将消息更新标记为「非紧急」，避免阻塞输入等高优先级交互&lt;/span&gt;&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #dcdcaa;&quot;&gt;startMessagesTransition&lt;/span&gt;(() &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #dcdcaa;&quot;&gt;setMessages&lt;/span&gt;((&lt;span style=&quot;color: #9cdcfe;&quot;&gt;prev&lt;/span&gt;) &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #c586c0;&quot;&gt;return&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;prev&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;map&lt;/span&gt;((&lt;span style=&quot;color: #9cdcfe;&quot;&gt;msg&lt;/span&gt;) &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;          &lt;span style=&quot;color: #9cdcfe;&quot;&gt;msg&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;id&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;===&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt;&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #d4d4d4;&quot;&gt;?&lt;/span&gt; { &lt;span style=&quot;color: #d4d4d4;&quot;&gt;...&lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;msg&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;content&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;status&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;updatedAt&lt;/span&gt; }&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;msg&lt;/span&gt;&lt;/div&gt;&lt;div&gt;        );&lt;/div&gt;&lt;div&gt;      });&lt;/div&gt;&lt;div&gt;    });&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;cid&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;currentConversationIdRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #c586c0;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #4fc1ff;&quot;&gt;cid&lt;/span&gt;) {&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #dcdcaa;&quot;&gt;dbUpdateMessage&lt;/span&gt;(&lt;span style=&quot;color: #4fc1ff;&quot;&gt;cid&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt;, { &lt;span style=&quot;color: #9cdcfe;&quot;&gt;content&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;status&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;updatedAt&lt;/span&gt; }).&lt;span style=&quot;color: #dcdcaa;&quot;&gt;catch&lt;/span&gt;((&lt;span style=&quot;color: #9cdcfe;&quot;&gt;err&lt;/span&gt;) &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #9cdcfe;&quot;&gt;console&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;warn&lt;/span&gt;(&lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;[conversationDb] updateMessage failed:&#39;&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;err&lt;/span&gt;)&lt;/div&gt;&lt;div&gt;      );&lt;/div&gt;&lt;div&gt;    }&lt;/div&gt;&lt;div&gt;  }, [&lt;span style=&quot;color: #dcdcaa;&quot;&gt;startMessagesTransition&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;currentConversationIdRef&lt;/span&gt;]);&lt;/div&gt;&lt;br&gt;&lt;div&gt;  &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;clearStreamContent&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useCallback&lt;/span&gt;(() &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentAIMessageIdRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #569cd6;&quot;&gt;null&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentRoundIdRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #569cd6;&quot;&gt;null&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #4fc1ff;&quot;&gt;streamContentMapRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;clear&lt;/span&gt;();&lt;/div&gt;&lt;div&gt;  }, []);&lt;/div&gt;&lt;br&gt;&lt;div&gt;  &lt;span style=&quot;color: #6a9955;&quot;&gt;// 创建新的AI消息并设置相关ref（封装重复逻辑）&lt;/span&gt;&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;createNewAIMessage&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useCallback&lt;/span&gt;((&lt;span style=&quot;color: #9cdcfe;&quot;&gt;roundId&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;number&lt;/span&gt;)&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;Message&lt;/span&gt; &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;msg&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;addMessage&lt;/span&gt;(&lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;answer&#39;&lt;/span&gt;, &lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;&#39;&lt;/span&gt;, &lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;streaming&#39;&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentAIMessageIdRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;msg&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;id&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentRoundIdRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;roundId&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #4fc1ff;&quot;&gt;streamContentMapRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;set&lt;/span&gt;(&lt;span style=&quot;color: #4fc1ff;&quot;&gt;msg&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;id&lt;/span&gt;, &lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;&#39;&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #c586c0;&quot;&gt;return&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;msg&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;  }, [&lt;span style=&quot;color: #dcdcaa;&quot;&gt;addMessage&lt;/span&gt;]);&lt;/div&gt;&lt;br&gt;&lt;div&gt;  &lt;span style=&quot;color: #6a9955;&quot;&gt;// 清理单个消息的相关数据&lt;/span&gt;&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;clearMessage&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useCallback&lt;/span&gt;((&lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt;) &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #4fc1ff;&quot;&gt;streamContentMapRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;delete&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #4fc1ff;&quot;&gt;lastUpdateTimeRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;delete&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #c586c0;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentAIMessageIdRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;===&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt;) {&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentAIMessageIdRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #569cd6;&quot;&gt;null&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentRoundIdRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #569cd6;&quot;&gt;null&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    }&lt;/div&gt;&lt;div&gt;  }, []);&lt;/div&gt;&lt;br&gt;&lt;div&gt;  &lt;span style=&quot;color: #6a9955;&quot;&gt;// 累加流式内容&lt;/span&gt;&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;accumulateStreamContent&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useCallback&lt;/span&gt;((&lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;newText&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt;)&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt; &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #6a9955;&quot;&gt;// 获取或初始化该消息的累计内容&lt;/span&gt;&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #c586c0;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #d4d4d4;&quot;&gt;!&lt;/span&gt;&lt;span style=&quot;color: #4fc1ff;&quot;&gt;streamContentMapRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;has&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt;)) {&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #4fc1ff;&quot;&gt;streamContentMapRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;set&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt;, &lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;&#39;&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;    }&lt;/div&gt;&lt;div&gt;    &lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentContent&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;streamContentMapRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;get&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt;) &lt;span style=&quot;color: #d4d4d4;&quot;&gt;||&lt;/span&gt; &lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;&#39;&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    &lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #c586c0;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #d4d4d4;&quot;&gt;!&lt;/span&gt;&lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentContent&lt;/span&gt;) {&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #c586c0;&quot;&gt;return&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;newText&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    }&lt;/div&gt;&lt;div&gt;    &lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #c586c0;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #9cdcfe;&quot;&gt;newText&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;startsWith&lt;/span&gt;(&lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentContent&lt;/span&gt;)) {&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #c586c0;&quot;&gt;return&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;newText&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    }&lt;/div&gt;&lt;div&gt;    &lt;/div&gt;&lt;div&gt;    &lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #6a9955;&quot;&gt;// 累加格式处理：查找 currentContent 的后缀，看 newText 是否以该后缀开头&lt;/span&gt;&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #569cd6;&quot;&gt;let&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;commonSuffix&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;&#39;&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #569cd6;&quot;&gt;let&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;maxLen&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;Math&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;min&lt;/span&gt;(&lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentContent&lt;/span&gt;.&lt;span style=&quot;color: #4fc1ff;&quot;&gt;length&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;newText&lt;/span&gt;.&lt;span style=&quot;color: #4fc1ff;&quot;&gt;length&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;    &lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #c586c0;&quot;&gt;for&lt;/span&gt; (&lt;span style=&quot;color: #569cd6;&quot;&gt;let&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;i&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;maxLen&lt;/span&gt;; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;i&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;gt;=&lt;/span&gt; &lt;span style=&quot;color: #b5cea8;&quot;&gt;1&lt;/span&gt;; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;i&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;--&lt;/span&gt;) {&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;suffix&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentContent&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;slice&lt;/span&gt;(&lt;span style=&quot;color: #d4d4d4;&quot;&gt;-&lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;i&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #c586c0;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #9cdcfe;&quot;&gt;newText&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;startsWith&lt;/span&gt;(&lt;span style=&quot;color: #4fc1ff;&quot;&gt;suffix&lt;/span&gt;)) {&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #9cdcfe;&quot;&gt;commonSuffix&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;suffix&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #c586c0;&quot;&gt;break&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;      }&lt;/div&gt;&lt;div&gt;    }&lt;/div&gt;&lt;div&gt;    &lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #c586c0;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #9cdcfe;&quot;&gt;commonSuffix&lt;/span&gt;) {&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;newPart&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;newText&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;slice&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;commonSuffix&lt;/span&gt;.&lt;span style=&quot;color: #4fc1ff;&quot;&gt;length&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #c586c0;&quot;&gt;return&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentContent&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;+&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;newPart&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    } &lt;span style=&quot;color: #c586c0;&quot;&gt;else&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #c586c0;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #9cdcfe;&quot;&gt;newText&lt;/span&gt;.&lt;span style=&quot;color: #4fc1ff;&quot;&gt;length&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;lt;&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentContent&lt;/span&gt;.&lt;span style=&quot;color: #4fc1ff;&quot;&gt;length&lt;/span&gt;) {&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #c586c0;&quot;&gt;return&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;currentContent&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;+&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;newText&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;      } &lt;span style=&quot;color: #c586c0;&quot;&gt;else&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #c586c0;&quot;&gt;return&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;newText&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;      }&lt;/div&gt;&lt;div&gt;    }&lt;/div&gt;&lt;div&gt;  }, []);&lt;/div&gt;&lt;br&gt;&lt;div&gt;  &lt;span style=&quot;color: #6a9955;&quot;&gt;// 带节流的消息更新（封装节流逻辑）&lt;/span&gt;&lt;/div&gt;&lt;div&gt;  &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;updateMessageWithThrottle&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;useCallback&lt;/span&gt;((&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;content&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;string&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;status&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;Message&lt;/span&gt;[&lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;status&#39;&lt;/span&gt;]&lt;/div&gt;&lt;div&gt;  ) &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;now&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;Date&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;now&lt;/span&gt;();&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;lastUpdate&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;lastUpdateTimeRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;get&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt;) &lt;span style=&quot;color: #d4d4d4;&quot;&gt;||&lt;/span&gt; &lt;span style=&quot;color: #b5cea8;&quot;&gt;0&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;timeSinceLastUpdate&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;now&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;-&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;lastUpdate&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    &lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #6a9955;&quot;&gt;// 如果距离上次更新超过阈值，或者消息已结束，立即更新&lt;/span&gt;&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;shouldUpdateImmediately&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;timeSinceLastUpdate&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;gt;=&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;UPDATE_INTERVAL&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;||&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;status&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;===&lt;/span&gt; &lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;finished&#39;&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;    &lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #c586c0;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #4fc1ff;&quot;&gt;shouldUpdateImmediately&lt;/span&gt;) {&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #dcdcaa;&quot;&gt;updateMessage&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;content&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;status&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #4fc1ff;&quot;&gt;lastUpdateTimeRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;set&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt;, &lt;span style=&quot;color: #4fc1ff;&quot;&gt;now&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;    } &lt;span style=&quot;color: #c586c0;&quot;&gt;else&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #6a9955;&quot;&gt;// 使用 requestAnimationFrame 调度更新，确保在浏览器重绘前执行&lt;/span&gt;&lt;/div&gt;&lt;div&gt;      &lt;span style=&quot;color: #c586c0;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #4fc1ff;&quot;&gt;rafIdRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;===&lt;/span&gt; &lt;span style=&quot;color: #569cd6;&quot;&gt;null&lt;/span&gt;) {&lt;/div&gt;&lt;div&gt;        &lt;span style=&quot;color: #4fc1ff;&quot;&gt;rafIdRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;requestAnimationFrame&lt;/span&gt;(() &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;          &lt;span style=&quot;color: #6a9955;&quot;&gt;// 批量更新所有待更新的消息&lt;/span&gt;&lt;/div&gt;&lt;div&gt;          &lt;span style=&quot;color: #4fc1ff;&quot;&gt;streamContentMapRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;forEach&lt;/span&gt;((&lt;span style=&quot;color: #9cdcfe;&quot;&gt;streamContent&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;msgId&lt;/span&gt;) &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;lastUpd&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;lastUpdateTimeRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;get&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;msgId&lt;/span&gt;) &lt;span style=&quot;color: #d4d4d4;&quot;&gt;||&lt;/span&gt; &lt;span style=&quot;color: #b5cea8;&quot;&gt;0&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;timeSince&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #4ec9b0;&quot;&gt;Date&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;now&lt;/span&gt;() &lt;span style=&quot;color: #d4d4d4;&quot;&gt;-&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;lastUpd&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;            &lt;span style=&quot;color: #c586c0;&quot;&gt;if&lt;/span&gt; (&lt;span style=&quot;color: #4fc1ff;&quot;&gt;timeSince&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;gt;=&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;UPDATE_INTERVAL&lt;/span&gt;) {&lt;/div&gt;&lt;div&gt;              &lt;span style=&quot;color: #569cd6;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;msgStatus&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;msgId&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;===&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;messageId&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;?&lt;/span&gt; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;status&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;streaming&#39;&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;              &lt;span style=&quot;color: #dcdcaa;&quot;&gt;updateMessage&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;msgId&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;streamContent&lt;/span&gt;, &lt;span style=&quot;color: #4fc1ff;&quot;&gt;msgStatus&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;              &lt;span style=&quot;color: #4fc1ff;&quot;&gt;lastUpdateTimeRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;set&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;msgId&lt;/span&gt;, &lt;span style=&quot;color: #4ec9b0;&quot;&gt;Date&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;now&lt;/span&gt;());&lt;/div&gt;&lt;div&gt;            }&lt;/div&gt;&lt;div&gt;          });&lt;/div&gt;&lt;div&gt;          &lt;span style=&quot;color: #4fc1ff;&quot;&gt;rafIdRef&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;current&lt;/span&gt; &lt;span style=&quot;color: #d4d4d4;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #569cd6;&quot;&gt;null&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;        });&lt;/div&gt;&lt;div&gt;      }&lt;/div&gt;&lt;div&gt;    }&lt;/div&gt;&lt;div&gt;  }, [&lt;span style=&quot;color: #dcdcaa;&quot;&gt;updateMessage&lt;/span&gt;]);&lt;/div&gt;&lt;br&gt;&lt;div&gt;  &lt;span style=&quot;color: #c586c0;&quot;&gt;return&lt;/span&gt; {&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;messages&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #dcdcaa;&quot;&gt;addMessage&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #dcdcaa;&quot;&gt;updateMessage&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #dcdcaa;&quot;&gt;setMessages&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;currentConversationIdRef&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;currentAIMessageIdRef&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;currentRoundIdRef&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;expectMoreContentAfterToolRef&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;streamContentMapRef&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;lastUpdateTimeRef&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;rafIdRef&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;clawBotRunToMessageRef&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #9cdcfe;&quot;&gt;clawBotStreamContentRef&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #dcdcaa;&quot;&gt;clearStreamContent&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #dcdcaa;&quot;&gt;createNewAIMessage&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #dcdcaa;&quot;&gt;clearMessage&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #dcdcaa;&quot;&gt;accumulateStreamContent&lt;/span&gt;,&lt;/div&gt;&lt;div&gt;    &lt;span style=&quot;color: #dcdcaa;&quot;&gt;updateMessageWithThrottle&lt;/span&gt;,&lt;/div&gt