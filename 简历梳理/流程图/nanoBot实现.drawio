style=&quot;color: #cccccc;&quot;&gt;ipcRenderer&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;on&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;nanobot:executeAsyncProgress&#39;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;handler&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre;&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;return&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; () &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;ipcRenderer&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;removeListener&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;nanobot:executeAsyncProgress&#39;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;handler&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre;&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; },&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre;&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; },&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: rgb(228, 228, 228); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; font-weight: normal; white-space: pre;&quot;&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;};&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
