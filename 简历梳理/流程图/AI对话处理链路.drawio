e-height: 19px;white-space: pre;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;// 发给后端：“我是谁(appId)、在哪个房间(roomId)、属于哪个任务(taskId)、这次要执行什么命令(command)”&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;req&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;appId&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;rtcCfg&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;appId&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;roomId&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;rtcCfg&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;roomId&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;taskId&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;botCfg&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;taskId&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;command&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;...&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221); font-style: italic;&quot;&gt;options&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; };&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;// 用 ApiClient 发请求： HTTP POST&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb