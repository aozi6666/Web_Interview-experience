te&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;now&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;()&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;}&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;_&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;${&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;Math&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;random&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;().&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;toString&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;36&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;).&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;substr&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;2&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;9&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;)&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;}&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;`&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;newMessage&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;Message&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6