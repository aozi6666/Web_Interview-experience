ot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;length&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;||&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;!&lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;Number&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;isFinite&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;groupId&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)) &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;return&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; false;&lt;/span&gt;&lt;/div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;// 把图片信息作为 &lt;code data-start=&quot;1868&quot; data-end=&quot;1881&quot;&gt;imageConfig&lt;/code&gt; 一起发请求&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;imageConfig&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;Action&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&quot;insert&quot;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;GroupID&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;groupId&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;ImageType&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;options&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;imageType&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;||&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&quot;url&quot;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;Images&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #cccccc;&quot;&gt;images&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; };&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;return&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;await&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #cc7c8a;&quot;&gt;this&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;updateVoiceChat&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&quot;ExternalTextToLLM&quot;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;message&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;options&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;message&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;interruptMode&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;imageConfig&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; });&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; }&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
