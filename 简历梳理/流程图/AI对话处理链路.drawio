        <mxCell id="2XWRjSxhnGw2jaiD-T-z-21" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;class&lt;/span&gt; &lt;span style=&quot;color: rgb(135, 195, 255);&quot;&gt;BotManager&lt;/span&gt; { &lt;/div&gt;&lt;div&gt;    // 构造 config&lt;/div&gt;&lt;div&gt;   &amp;nbsp;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;constructor&lt;/span&gt;(&lt;span style=&quot;color: rgb(214, 214, 221); font-style: italic;&quot;&gt;config&lt;/span&gt;) {&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 19px;&quot;&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #cc7c8a;&quot;&gt;this&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;config&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;config&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;instanceof&lt;/span&gt; &lt;span style=&quot;color: #87c3ff;&quot;&gt;AgentConfig&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;?&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;font-style: italic;&quot;&gt;config&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;:&lt;/span&gt; &lt;span style=&quot;color: #87c3ff;&quot;&gt;AgentConfig&lt;/span&gt;.&lt;span style=&quot;color: #efb080;&quot;&gt;Create&lt;/span&gt;();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #cc7c8a;&quot;&gt;this&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;apiClient&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #82d2ce;&quot;&gt;new&lt;/span&gt; &lt;span style=&quot;color: #87c3ff;&quot;&gt;ApiClient&lt;/span&gt;(&lt;span style=&quot;color: #cc7c8a;&quot;&gt;this&lt;/span&gt;.&lt;span style=&quot;color: #d6d6dd;&quot;&gt;config&lt;/span&gt;.&lt;span style=&quot;color: #efb080;&quot;&gt;GetServerConfig&lt;/span&gt;().&lt;span style=&quot;color: #aaa0fa;&quot;&gt;enableLog&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;/div&gt;&lt;div&gt;     ...&lt;/div&gt;&lt;div&gt;     // 组装请求体 → 调 ApiClient 发 HTTP&lt;/div&gt;&lt;div&gt;     &lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;async&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(239, 176, 128); font-weight: bold;&quot;&gt;updateVoiceChat&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221); font-style: italic;&quot;&gt;command&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221); font-style: italic;&quot;&gt;options&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; {}) {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;// 从 config，拿到“身份信息”&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; { &lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;rtcCfg&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;botCfg&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228,