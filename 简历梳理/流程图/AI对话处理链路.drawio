&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;return&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; { &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;success&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; false, &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;error&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(227, 148, 220);&quot;&gt;&quot;apiUrl/authToken 为空&quot;&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; };&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;if&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;!&lt;/span&gt;&lt;span style=&quot;color: rgb(204, 204, 204);&quot;&gt;botCfg&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;taskId&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;) &lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;return&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; { &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;success&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; false, &lt;/span&gt;&lt;span style=&quot;color: rgb(170, 160, 250);&quot;&gt;error&lt;/span&gt;&lt;span style=&quot;color: rgb(214, 214, 221);&quot;&gt;:&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&