        <mxCell id="IPRdIbJHup9Mvk_TXT2r-29" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;&lt;div style=&quot;line-height: 19px;&quot;&gt;&lt;div&gt;&lt;span style=&quot;font-style: italic;&quot;&gt;// tools工具&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;import&lt;/span&gt; { &lt;span style=&quot;color: rgb(135, 195, 255);&quot;&gt;createSystemInfoTool&lt;/span&gt; } &lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;from&lt;/span&gt; &lt;span style=&quot;color: rgb(227, 148, 220);&quot;&gt;&#39;../lib/tools/systemInfo&#39;&lt;/span&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;  &lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;// 工具实例（Ref保存）&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;systemInfoToolRef&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;useRef&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;ReturnType&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;typeof&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;createSystemInfoTool&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;|&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;null&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;gt;(null);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: italic;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(235, 200, 141);&quot;&gt;useEffect&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;(() &lt;/span&gt;&lt;span style=&quot;color: rgb(130, 210, 206);&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(228, 228, 228);&quot;&gt;&lt;i&gt;   ... &lt;/i&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-style: italic;&quot;&gt;  // 注册函数调用工具：系统信息查询&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&lt;div style=&quot;line-height: 19px;&quot;&gt;&lt;div&gt;&amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;systemInfoTool&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #efb080;&quot;&gt;createSystemInfoTool&lt;/span&gt;();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;systemInfoToolRef&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;current&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;systemInfoTool&lt;/span&gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &lt;span style=&quot;font-style: italic;&quot;&gt;// 注册：将工具声明和处理函数注册到会话中&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;session&lt;/span&gt;.&lt;span style=&quot;color: #efb080;&quot;&gt;AddFunctionTool&lt;/span&gt;(&lt;span style=&quot;color: #aaa0fa;&quot;&gt;systemInfoTool&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;declaration&lt;/span&gt;, &lt;span style=&quot;color: #aaa0fa;&quot;&gt;systemInfoTool&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;handler&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt; &amp;nbsp;&lt;span style=&quot;font-style: italic;&quot;&gt;// 注册函数调用工具：nanobot_router（本地 nanobot 多步骤推理 + Skills，经 HTTP 网关调用）&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 19px;&quot;&gt;&lt;div&gt;&amp;nbsp; &lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;nanobotRouterTool&lt;/span&gt; &lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt; &lt;span style=&quot;color: #efb080;&quot;&gt;createNanobotRouterTool&lt;/span&gt;();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &lt;span style=&quot;color: #aaa0fa;&quot;&gt;session&lt;/span&gt;.&lt;span style=&quot;color: #efb080;&quot;&gt;AddFunctionTool&lt;/span&gt;(&lt;span style=&quot;color: #aaa0fa;&quot;&gt;nanobotRouterTool&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;declaration&lt;/span&gt;, &lt;span style=&quot;color: #aaa0fa;&quot;&gt;nanobotRouterTool&lt;/span&gt;.&lt;span style=&quot;color: #aaa0fa;&quot;&gt;handler&lt;/span&gt;);&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
