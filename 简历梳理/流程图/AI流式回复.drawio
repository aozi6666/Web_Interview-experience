        <mxCell id="GAhkB8aJEiN_ptrqmjw_-20" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;// 流式内容累计Map：为每个messageId维护独立的streamContent（防止Chunk被覆盖）&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;streamContentMapRef&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;useRef&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;Map&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;string&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;string&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;gt;&amp;gt;(&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;new&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #87c3ff;&quot;&gt;Map&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;());&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
