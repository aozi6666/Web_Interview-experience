        <mxCell id="IPRdIbJHup9Mvk_TXT2r-27" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;ul data-start=&quot;989&quot; data-end=&quot;1122&quot;&gt;&lt;li data-start=&quot;989&quot; data-end=&quot;1122&quot;&gt;&lt;p data-start=&quot;991&quot; data-end=&quot;1015&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;&lt;code data-start=&quot;991&quot; data-end=&quot;1000&quot; style=&quot;&quot;&gt;Session&lt;/code&gt; 内部偷偷创建了两个“员工”：&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;ol data-start=&quot;1018&quot; data-end=&quot;1122&quot;&gt;&lt;li data-start=&quot;1018&quot; data-end=&quot;1066&quot;&gt;&lt;p data-start=&quot;1021&quot; data-end=&quot;1066&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;&lt;span data-start=&quot;1021&quot; data-end=&quot;1034&quot;&gt;ChatAgent&lt;/span&gt;：负责 RTC 房间连接 + 收消息 + 分发字幕/工具调用&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li data-start=&quot;1069&quot; data-end=&quot;1122&quot;&gt;&lt;p data-start=&quot;1072&quot; data-end=&quot;1122&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;&lt;span data-start=&quot;1072&quot; data-end=&quot;1086&quot; style=&quot;&quot;&gt;BotManager&lt;/span&gt;：负责调用 HTTP 接口让 Bot/LLM 开始工作、发消息、更新配置&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p data-start=&quot;1124&quot; data-end=&quot;1260&quot;&gt;&lt;/p&gt;" vertex="1">
