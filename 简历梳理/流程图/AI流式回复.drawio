: #efb080;&quot;&gt;set&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;msg&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;id&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;&#39;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; } &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;else&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;if&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;isNewReply&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;&amp;amp;&amp;amp;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;isJsonContent&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;) {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;// 如果收到的是JSON内容，但判断为新回复，可能是格式异常&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;msg&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&l